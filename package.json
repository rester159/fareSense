{
  "name": "doki",
  "version": "0.1.0",
  "private": true,
  "description": "DOKI — Kawaii Cat Battle & Breeding Game",
  "scripts": {
    "setup": "node scripts/setup.js",
    "backend": "node backend/index.js",
    "backend:dev": "node --watch backend/index.js",
    "frontend": "cd frontend && npx expo start",
    "build:web": "cd frontend && npm run build:web",
    "db:migrate": "node backend/run-migrations.js",
    "db:seed": "node backend/run-seeds.js"
  },
  "engines": {
    "node": ">=18"
  }
}
